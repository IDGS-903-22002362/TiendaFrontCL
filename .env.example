# ==============================
# Storefront API (required)
# ==============================
# Nota: este frontend usa rutas internas con prefijo /api/*,
# por lo que con esta base se construyen URLs finales tipo /api/api/productos.

# Local backend base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Optional server-side fallback base URL (Route Handlers / Server Actions)
API_BASE_URL=http://localhost:3000/api

# ==============================
# Firebase Web SDK (optional in this phase)
# ==============================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ==============================
# Production reference values
# ==============================
# NEXT_PUBLIC_API_BASE_URL=https://us-central1-e-comerce-leon.cloudfunctions.net/api
# API_BASE_URL=https://us-central1-e-comerce-leon.cloudfunctions.net/api
