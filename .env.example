# ==============================
# Storefront API (required)
# ==============================
# Nota: este frontend usa rutas internas con prefijo /api/*,
# por lo que con esta base se construyen URLs finales tipo /api/api/productos.

# Local backend base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Optional server-side fallback base URL (Route Handlers / Server Actions)
API_BASE_URL=http://localhost:3000/api

# ==============================
# Firebase Web SDK (required for login)
# ==============================
# Opción recomendada: usar proyecto Firebase exclusivo para Auth
# (sobrescribe los NEXT_PUBLIC_FIREBASE_* si se define)
NEXT_PUBLIC_AUTH_FIREBASE_API_KEY=
NEXT_PUBLIC_AUTH_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_AUTH_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_AUTH_FIREBASE_APP_ID=

# Compatibilidad (legacy)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51SxZMWAcXWVVDBOGSUddGSABMplWjSCqbyq1LC0WTwRlZ20JSRXI1GjXtlDglZhm5Cvhv4dYcMxMpZU57xdaAyzO000OF4wNKD

